# ============================================================
#  ADICIONARES GLOBAL INC — Variáveis de Ambiente
#  Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Chave da API do Google Gemini (obtenha em https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Configurações do Supabase (obtenha em https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
